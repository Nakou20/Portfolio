<!-- views/home.ejs -->

<!-- Hero Section -->
<section class="min-h-[90vh] flex items-center pt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
            <!-- Left Content -->
            <div class="space-y-8 animate-slide-up">
                                
                <h1 class="text-6xl md:text-8xl font-black text-white leading-none tracking-tighter">
                    <span class="block">Futur</span>
                    <span class="block text-gradient">Data </span>
                    <span class="block">Analyst</span>
                </h1>
                
                <p class="text-xl text-gray-400 max-w-xl leading-relaxed">
                    Combinaison d'innovation, d'expertise technique et d'une passion débordante pour la donnée.
                </p>
                
                <div class="flex flex-wrap gap-4 pt-4">
                    <a href="/projects" class="btn-primary flex items-center group">
                        <span>Voir mes Projets</span>
                        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                    </a>
                    <a href="/contact" class="btn-secondary">
                        Me Contacter
                    </a>
                </div>
            </div>

            <!-- Right Visual (Mockup) -->
            <div class="relative animate-fade-in animate-delay-200">
                <div class="absolute -inset-4 bg-gradient-to-br from-primary/20 to-secondary/20 rounded-3xl blur-3xl opacity-50"></div>
                <div class="relative glass-card overflow-hidden aspect-video group">
                    <img id="hero-mockup" src="/images/hero-dashboard.jpg" alt="Dashboard Mockup" class="w-full h-full object-cover">
                    <div class="absolute inset-0 bg-gradient-to-t from-dark/60 to-transparent"></div>
                    <div class="absolute bottom-6 left-6 right-6">
                        <div class="flex items-center space-x-3 p-3 glass-card bg-white/5 backdrop-blur-md">
                            <div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-white font-bold">JD</div>
                            <div>
                                <div class="text-xs font-bold text-white">Dernière mise à jour</div>
                                <div class="text-[10px] text-gray-400">Il y a 2 minutes</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Mission & Stats -->
<section class="py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
        <div class="glass-card p-12 relative overflow-hidden">
            <!-- Background Decorative Element -->
            <div class="absolute top-0 right-0 -mr-20 -mt-20 w-80 h-80 bg-primary/10 rounded-full blur-3xl"></div>
            
            <div class="grid lg:grid-cols-3 gap-16 relative z-10">
                <div class="lg:col-span-2 space-y-6">
                    <h2 class="text-3xl font-bold text-white">Ma Mission.</h2>
                    <p class="text-lg text-gray-400 leading-relaxed max-w-2xl">
                        Concevoir des solutions numériques qui ne se contentent pas d'être fonctionnelles, mais qui inspirent et facilitent la vie des utilisateurs. Mon approche mêle rigueur technique et créativité visuelle pour des résultats d'exception.
                    </p>
                </div>
                
                <div class="grid grid-cols-2 gap-8">
                    <div class="space-y-1">
                        <div class="text-5xl font-black text-white"><%= stats.yearsExperience %>+</div>
                        <div class="text-sm font-bold text-primary-light uppercase tracking-widest">Années</div>
                    </div>
                    <div class="space-y-1">
                        <div class="text-5xl font-black text-white"><%= stats.projectsCompleted %></div>
                        <div class="text-sm font-bold text-secondary-light uppercase tracking-widest">Projets</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Stack Tech Section -->
<section class="py-24 px-4 sm:px-6 lg:px-8 relative">
    <!-- background glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] bg-secondary/5 rounded-full blur-[120px]"></div>
    
    <div class="max-w-7xl mx-auto relative z-10">
        <div class="text-center mb-16 space-y-4">
            <h2 class="section-title">Stack Technique & Écosystème</h2>
            <p class="text-gray-400 max-w-2xl mx-auto">Un arsenal technologique moderne pour des applications robustes, scalables et performantes.</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
            <% const stacks = [
                { title: 'Frontend', tech: 'React, Vue, Next.js, Tailwind', icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', color: 'primary' },
                { title: 'Backend', tech: 'Node.js, Express, Java, Python', icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2m0 0a2 2 0 002-2v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4a2 2 0 012-2', color: 'secondary' },
                { title: 'Database', tech: 'Postgres, MongoDB, MySQL', icon: 'M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4', color: 'primary' },
                { title: 'DevOps', tech: 'Docker, AWS, CI/CD', icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4', color: 'secondary' }
            ] %>
            
            <% stacks.forEach(stack => { %>
                <div class="glass-card p-8 group hover:scale-[1.02] transition-all">
                    <div class="w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center mb-6 group-hover:bg-<%= stack.color %>/20 group-hover:border-<%= stack.color %>/30 transition-colors">
                        <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="<%= stack.icon %>"/></svg>
                    </div>
                    <h3 class="text-xl font-bold text-white mb-2"><%= stack.title %></h3>
                    <p class="text-sm text-gray-500 line-clamp-2"><%= stack.tech %></p>
                    <div class="mt-6 flex items-center text-xs font-bold text-primary-light opacity-0 group-hover:opacity-100 transition-opacity">
                        <span>Explorer</span>
                        <svg class="w-3 h-3 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</section>
