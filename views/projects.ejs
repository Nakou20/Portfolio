<!-- views/projects.ejs -->

<section class="min-h-screen py-32 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
        <!-- Header -->
        <div class="mb-20 space-y-4 max-w-3xl animate-slide-up">
            <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full bg-secondary/10 border border-secondary/20 text-secondary-light text-xs font-bold uppercase tracking-wider">
                <span>Mes Réalisations</span>
            </div>
            <h1 class="text-6xl font-black text-white tracking-tighter"><span class="text-gradient">Expériences</span></h1>
            <p class="text-xl text-gray-400 leading-relaxed">
                Une sélection rigoureuse de projets démontrant mon expérience.
            </p>
        </div>

        <!-- Projects Grid -->
        <div class="grid lg:grid-cols-2 gap-10 mb-20">
            <% projects.forEach((project, index) => { %>
                <div class="glass-card group flex flex-col md:flex-row overflow-hidden hover:scale-[1.01] transition-all duration-500 animate-slide-up bg-white/[0.02]" style="animation-delay: <%= index * 100 %>ms">
                    <!-- Image content -->
                    <div class="md:w-1/2 relative overflow-hidden aspect-video md:aspect-auto">
                        <img src="<%= project.image %>" alt="<%= project.title %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                        <div class="absolute inset-0 bg-gradient-to-r from-dark/40 to-transparent"></div>
                        <div class="absolute top-4 left-4">
                            <span class="px-3 py-1 bg-white/10 backdrop-blur-md border border-white/10 rounded-full text-[10px] font-bold text-white uppercase tracking-widest">
                                Projet <%= index + 1 %>
                            </span>
                        </div>
                    </div>

                    <!-- Details -->
                    <div class="md:w-1/2 p-8 flex flex-col justify-between">
                        <div>
                            <h3 class="text-2xl font-bold text-white mb-3 group-hover:text-primary-light transition-colors"><%= project.title %></h3>
                            <p class="text-gray-400 text-sm leading-relaxed mb-6 line-clamp-3">
                                <%= project.description %>
                            </p>
                            
                            <!-- Tags -->
                            <div class="flex flex-wrap gap-2 mb-8">
                                <% project.technologies.slice(0, 3).forEach((tech) => { %>
                                    <span class="text-[10px] font-bold px-2 py-1 bg-white/5 border border-white/10 rounded text-gray-300 uppercase tracking-widest">
                                        <%= tech %>
                                    </span>
                                <% }); %>
                                <% if (project.technologies.length > 3) { %>
                                    <span class="text-[10px] font-bold px-2 py-1 text-gray-500 uppercase">
                                        +<%= project.technologies.length - 3 %>
                                    </span>
                                <% } %>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="flex items-center space-x-4">
                            <a href="/projects/<%= project.id %>" class="px-6 py-2.5 bg-primary text-white text-xs font-bold rounded-xl hover:bg-primary-dark transition-all">
                                Voir Détails
                            </a>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>
</section>
